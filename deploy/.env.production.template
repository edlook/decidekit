# ─── App ────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=decidekitdb
DB_USER=postgres
DB_PASS=CHANGE_ME_STRONG_PASSWORD

DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_PASSWORD@postgres:5432/decidekitdb

