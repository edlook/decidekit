# App
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001

# PostgreSQL
DATABASE_URL=postgresql://postgres:password@localhost:5432/decidekitdb
DB_HOST=localhost
DB_PORT=5432
DB_NAME=decidekitdb
DB_USER=postgres
DB_PASS=password

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_INDEX_PRODUCTS=products

# AI Providers (abstraction layer picks one)
AI_PROVIDER=openai
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
AI_MODEL_INTENT=gpt-4o-mini
AI_MODEL_RESULT=gpt-4o

# Affiliate Networks
AWIN_API_KEY=
AWIN_ADVERTISER_IDS=
RAKUTEN_TOKEN=
IMPACT_ACCOUNT_SID=
IMPACT_AUTH_TOKEN=

# JWT (admin only)
JWT_SECRET=change-me-in-production
JWT_EXPIRY=7d

# Analytics
POSTHOG_API_KEY=
